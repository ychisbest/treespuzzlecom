---
import '../styles/global.css';

const siteName = 'trees puzzle';
const siteUrl = 'https://treespuzzle.com';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteName}</title>
	</head>
	<body class="bg-stone-50 text-stone-900">
		<main class="mx-auto flex min-h-screen max-w-4xl flex-col justify-center gap-6 px-6 py-20">
			<p class="text-sm font-medium uppercase tracking-[0.3em] text-stone-500">Astro Starter</p>
			<h1 class="text-5xl font-semibold tracking-tight sm:text-6xl">{siteName}</h1>
			<p class="max-w-2xl text-lg text-stone-600">
				A fresh Astro project scaffolded from the official starter with Tailwind CSS and Sitemap configured.
			</p>
			<p class="text-base text-stone-700">
				Domain:
				<a class="underline decoration-stone-400 underline-offset-4" href={siteUrl}>{siteUrl}</a>
			</p>
		</main>
	</body>
</html>
